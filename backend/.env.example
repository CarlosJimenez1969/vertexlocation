# ====================================================
#  VertexMascota — Backend (Python/FastAPI)
# ====================================================

# --- App ---
APP_NAME=VertexMascota
ENV=development
DEBUG=true
API_PREFIX=/api
HOST=0.0.0.0
PORT=8000

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vertexmascota
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Cadena completa (tiene prioridad si se define). Usar postgresql+psycopg2://
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/vertexmascota

# --- JWT ---
JWT_SECRET=cambia_esto_por_una_clave_larga_y_aleatoria
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 días

# --- Traccar (plataforma GPS) ---
TRACCAR_URL=http://localhost:8082
TRACCAR_USER=admin@vertexmascota.com
TRACCAR_PASSWORD=admin
TRACCAR_JT808_PORT=5015
TRACCAR_WS_URL=ws://localhost:8082/api/socket

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- CORS (orígenes separados por coma) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Archivos ---
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5
